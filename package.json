{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "John Ian Buñag's personal portfolio",
  "repository": "git@gitlab.com:yvnbunag/yvnbunag.gitlab.io.git",
  "author": "Ian <jianbunag@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development nuxt",
    "clear": "rimraf .nuxt public",
    "build": "nuxt build",
    "generate": "yarn clear && NODE_ENV=production nuxt generate",
    "start": "nuxt start",
    "lint:js": "eslint --ext \".js,.vue\" --ignore-path .gitignore .",
    "lint:style": "stylelint \"**/*.{vue,css}\" --ignore-path .gitignore",
    "prepare": "husky install",
    "lint": "yarn lint:js && yarn lint:style"
  },
  "lint-staged": {
    "*.{js,vue}": "eslint",
    "*.{css,vue}": "stylelint"
  },
  "dependencies": {
    "@nuxtjs/composition-api": "^0.26.0",
    "core-js": "^3.15.1",
    "glitched-writer": "^2.0.29",
    "moment": "^2.29.1",
    "nuxt": "^2.15.7",
    "vue-typer": "^1.2.0",
    "vuetify": "^2.5.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.14.7",
    "@mdi/js": "^5.9.55",
    "@nuxt/types": "^2.15.7",
    "@nuxt/typescript-build": "^2.1.0",
    "@nuxtjs/eslint-config-typescript": "^6.0.1",
    "@nuxtjs/eslint-module": "^3.0.2",
    "@nuxtjs/robots": "^2.5.0",
    "@nuxtjs/sitemap": "^2.4.0",
    "@nuxtjs/style-resources": "^1.2.1",
    "@nuxtjs/stylelint-module": "^4.0.0",
    "@nuxtjs/vuetify": "^1.12.1",
    "@types/webpack-env": "^1.16.2",
    "@typescript-eslint/eslint-plugin": "^4.29.2",
    "cssnano": "^5.0.8",
    "eslint": "^7.29.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.24.0",
    "eslint-plugin-nuxt": "^2.0.0",
    "eslint-plugin-vue": "^7.16.0",
    "husky": "^6.0.0",
    "lint-staged": "^10.5.4",
    "node-sass": "^6.0.1",
    "node-sass-json-importer": "^4.3.0",
    "rimraf": "^3.0.2",
    "sass-loader": "^10.2.0",
    "sharp": "^0.29.0",
    "stylelint": "^13.13.1",
    "stylelint-config-standard": "^22.0.0",
    "stylelint-scss": "^3.20.1"
  },
  "engines": {
    "node": ">=16.5.0"
  }
}
